OLLAMA_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  # optional, für Cloud-Deployments

DATA_DIR=data
SOURCES_DIR=data/sources
BLOBS_DIR=data/blobs
REGISTRY_DB_PATH=data/registry.db

# LLM provider: "anthropic" oder "ollama"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=your-api-key-here

# Fallback Ollama (nur wenn LLM_PROVIDER=ollama)
# LLM_MODEL=qwen2.5:3b

VISION_MODEL=moondream
# E5-Modelle brauchen query:/passage:-Präfixe (werden automatisch erkannt).
# Leichtere Alternative (schlechtere Eval-Scores, s. docs/learnings.md §3): paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL=intfloat/multilingual-e5-large

INTENT_CONFIDENCE_THRESHOLD=0.7
MACHINE_RESOLUTION_THRESHOLD=0.75
RETRIEVAL_TOP_K=10

# Apple Silicon: MPS-Fallback auf CPU für nicht unterstützte float64-Ops
PYTORCH_ENABLE_MPS_FALLBACK=1
