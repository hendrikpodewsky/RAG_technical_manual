OLLAMA_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  # optional, für Cloud-Deployments

DATA_DIR=data
SOURCES_DIR=data/sources
BLOBS_DIR=data/blobs
REGISTRY_DB_PATH=data/registry.db

LLM_MODEL=qwen2.5:3b
VISION_MODEL=moondream
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

INTENT_CONFIDENCE_THRESHOLD=0.7
MACHINE_RESOLUTION_THRESHOLD=0.75
RETRIEVAL_TOP_K=10

# Apple Silicon: MPS-Fallback auf CPU für nicht unterstützte float64-Ops
PYTORCH_ENABLE_MPS_FALLBACK=1
